# ========================================
# KILLER GAME — конфигурация сервера
# Скопируй этот файл в .env и заполни
# ========================================

# Порт сервера (Railway/Render подставит сам)
PORT=3000

# Секретный ключ для JWT токенов — придумай длинную случайную строку
JWT_SECRET=замени_на_длинную_случайную_строку_минимум_32_символа

# ---- НАСТРОЙКИ EMAIL (для отправки кодов) ----
# Вариант 1: Gmail (нужно включить "Пароль приложения" в настройках Google)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=твой_gmail@gmail.com
MAIL_PASS=пароль_приложения_из_google

# Вариант 2: Mail.ru
# MAIL_HOST=smtp.mail.ru
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=твой@mail.ru
# MAIL_PASS=пароль_приложения

# Имя отправителя в письмах
MAIL_FROM=Killer Game <твой_gmail@gmail.com>

# URL сайта (для ссылок в письмах)
# На Railway это будет что-то вроде: https://killer-game.up.railway.app
APP_URL=http://localhost:3000
